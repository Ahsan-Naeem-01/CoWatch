{
  "name": "cowatch",
  "version": "1.0.0",
  "private": true,
  "description": "Watch the same local video in sync with friends. Frontend never uploads the file.",
  "workspaces": ["backend", "frontend"],
  "scripts": {
    "install:all": "npm install --workspaces --include-workspace-root",
    "dev:backend": "npm --workspace backend run dev",
    "dev:frontend": "npm --workspace frontend run dev",
    "dev": "npm-run-all --parallel dev:backend dev:frontend",
    "build:frontend": "npm --workspace frontend run build",
    "start:backend": "npm --workspace backend start"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
